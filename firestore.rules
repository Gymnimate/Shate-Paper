rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidStudySheet(data) {
      return data.userId is string && 
             data.topic is string && 
             data.topic.size() <= 1000 &&
             data.pages is list &&
             data.pages.size() > 0 &&
             data.pages.size() <= 20;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // StudySheets collection
    match /studySheets/{sheetId} {
      // Allow anyone to read sheets for the Explore feature and sharing
      allow read: if true;
      allow create: if isSignedIn() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidStudySheet(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                      request.resource.data.userId == resource.data.userId &&
                      isValidStudySheet(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
